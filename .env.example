# GitHub Personal Access Token (classic with `repo` scope, or fine-grained with repo read + clone)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Proxmox VE host (PVE 8 or 9).
# For a cluster, any one node is enough — requests are proxied to the node
# that owns the target guest. You may list several nodes comma-separated;
# the extras are used as connection failover targets.
#   PVE_HOST=192.168.1.10,192.168.1.11,192.168.1.12
PVE_HOST=192.168.1.10
PVE_PORT=8006
# API token: format is user@realm!tokenid for PVE_TOKEN_ID
PVE_TOKEN_ID=root@pam!dashdeploy
PVE_TOKEN_SECRET=00000000-0000-0000-0000-000000000000
# Homelab PVE usually uses a self-signed cert; set to true only if you have a valid cert
PVE_TLS_REJECT_UNAUTHORIZED=false

# HTTP server bind. Bind to the Tailscale interface IP in production so the app is tailnet-only.
BIND_HOST=0.0.0.0
PORT=3000

# Path to the server inventory file (defaults to config/servers.local.yml then config/servers.yml)
# SERVERS_FILE=config/servers.local.yml
